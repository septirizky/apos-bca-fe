<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="#FFFFFF"
    android:elevation="4dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <TextView
        android:id="@+id/headerBackButton"
        android:layout_width="36dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="&lt;"
        android:textColor="#0F172A"
        android:textSize="24sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- LEFT SIDE: BRANCH INFO -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/headerBranchName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PESISIR SEAFOOD"
            android:textColor="#1A0DAB"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- RIGHT SIDE: USER INFO -->
    <LinearLayout
        android:id="@+id/headerUserSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- DIVIDER -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="12dp"
            android:background="#E2E8F0" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/headerUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/headerDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 26, 14:30"
                android:textColor="#94A3B8"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
