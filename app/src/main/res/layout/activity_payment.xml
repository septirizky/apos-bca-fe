<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <include
        android:id="@+id/globalHeader"
        layout="@layout/layout_global_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:background="@drawable/bg_total_panel"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Tagihan"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtTotalBill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textColor="#1A05A3"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_paid_panel"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Terbayar"
                        android:textColor="#64748B"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtPaid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="#059669"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_remaining_panel"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sisa Pembayaran"
                        android:textColor="#64748B"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="#E11D48"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownPayment"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:text="DOWNPAYMENT"
                    android:textColor="#0F172A"
                    android:textSize="10sp"
                    app:icon="@drawable/ic_downpayment"
                    app:iconGravity="top"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:iconTint="#1A05A3"
                    app:cornerRadius="8dp"
                    app:strokeColor="#E2E8F0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDiscount"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="5dp"
                    android:layout_weight="1"
                    android:text="DISKON"
                    android:textColor="#0F172A"
                    android:textSize="10sp"
                    app:icon="@drawable/ic_discount"
                    app:iconGravity="top"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:iconTint="#F97316"
                    app:cornerRadius="8dp"
                    app:strokeColor="#E2E8F0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVoucher"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:text="VOUCHER"
                    android:textColor="#0F172A"
                    android:textSize="10sp"
                    app:icon="@drawable/ic_voucher"
                    app:iconGravity="top"
                    app:iconPadding="4dp"
                    app:iconSize="18dp"
                    app:iconTint="#10B981"
                    app:cornerRadius="8dp"
                    app:strokeColor="#E2E8F0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_payment_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRANSACTION ID"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtTransactionId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PS-0"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Table Number"
                            android:textColor="#64748B"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtTable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A-12"
                            android:textColor="#0F172A"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Timestamp"
                            android:textColor="#64748B"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtTimestamp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24 Oct 2023, 19:42"
                            android:textColor="#0F172A"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="ADD PAYMENT METHOD"
                    android:textColor="#1A05A3"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPaymentMethod"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical|start"
                    android:text="Pilih Metode Pembayaran..."
                    android:textAllCaps="false"
                    android:textColor="#0F172A"
                    app:cornerRadius="8dp"
                    app:strokeColor="#E2E8F0" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnPreviewReceipt"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashed_button"
                android:gravity="center"
                android:text="Preview Receipt / Bill"
                android:textColor="#334155"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/appliedSummaryContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCompletePayment"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#1A05A3"
        android:text="Selesaikan Pembayaran"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:cornerRadius="8dp" />
</LinearLayout>
