<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_order_card"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRANSACTION ID"
                android:textColor="#64748B"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pendingRefId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="monospace"
                android:textColor="#0F172A"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="988628" />
        </LinearLayout>

        <TextView
            android:id="@+id/pendingStatusChip"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:background="@drawable/bg_order_pax_chip"
            android:gravity="center"
            android:minWidth="72dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="#9A3412"
            android:textSize="9sp"
            android:textStyle="bold"
            tools:text="PENDING" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="#EEF2F7" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meja"
                android:textColor="#64748B"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/pendingTable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#334155"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metode"
                android:textColor="#64748B"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/pendingMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#334155"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="QRIS" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textColor="#64748B"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/pendingAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#1A05A3"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Rp709.500" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:contentDescription="Waktu"
            android:src="@drawable/ic_clock"
            app:tint="#64748B" />

        <TextView
            android:id="@+id/pendingTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:textColor="#475569"
            android:textSize="10sp"
            tools:text="17 Jun 2026, 11:16" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenApos"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Buka APOS"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2FF"
            app:cornerRadius="8dp"
            app:strokeColor="#C7D2FE" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:backgroundTint="#1A05A3"
            android:text="Cek Status"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />
    </LinearLayout>
</LinearLayout>
