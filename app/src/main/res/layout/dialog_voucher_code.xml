<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Input Kode Voucher"
            android:textColor="#1A0DAB"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            app:cardBackgroundColor="#F8FAFC"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/editVoucherCode"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:hint="MASUKKAN KODE"
                android:inputType="textCapCharacters"
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="#1A0DAB"
                android:textColorHint="#94A3B8"
                android:textSize="17sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckVoucher"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:text="Cek Voucher"
            android:textAllCaps="false"
            android:textColor="#1A0DAB"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="#C7D2FE"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/voucherInfoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_down_payment_row_selected"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtVoucherGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kelompok Voucher"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtVoucherStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Status Voucher"
                android:textColor="#64748B"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtVoucherPeriod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Masa Berlaku"
                android:textColor="#64748B"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtVoucherValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end"
                android:text="Rp 0"
                android:textColor="#1A0DAB"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveVoucher"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:text="Hapus Voucher"
            android:textAllCaps="false"
            android:textColor="#DC2626"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="12dp"
            app:strokeColor="#FECACA"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelVoucher"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Batal"
                android:textAllCaps="false"
                android:textColor="#94A3B8"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp" />

            <View
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyVoucher"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:backgroundTint="@color/button_primary_state"
                android:enabled="false"
                android:text="Terapkan"
                android:textAllCaps="false"
                android:textColor="@color/button_primary_text_state"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
