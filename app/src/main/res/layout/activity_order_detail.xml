<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F5F8"
    android:orientation="vertical">

    <!-- GLOBAL HEADER (FIXED) -->
    <include
        android:id="@+id/globalHeader"
        layout="@layout/layout_global_header" />

    <!-- SCROLLABLE CONTENT (ONLY ORDER LIST) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:orientation="vertical">

        <!-- TABLE INFO AREA (COMPACT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="36dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtTableNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Table 12"
                        android:textColor="#1A05A3"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- COMPACT PRINT BUTTON -->
                <ImageButton
                    android:id="@+id/btnPrint"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/print"
                    app:tint="#1A05A3"
                    android:padding="7dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Print Receipt" />
            </RelativeLayout>
        </LinearLayout>

        <!-- STICKY ORDER LIST HEADER (COMPACT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F6F5F8"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ORDER LIST"
                android:textColor="#334155"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtItemCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:drawable/editbox_background"
                android:backgroundTint="#1A05A3"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="0 Items"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- RECYCLERVIEW -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/detailRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- FIXED SUMMARY SECTION (BOTTOM) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:id="@+id/summaryBreakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#F1F5F9" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Amount"
                android:textColor="#0F172A"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Rp 0"
                android:textColor="#16A34A"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- BUTTONS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddDiscount"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:backgroundTint="#FFFFFF"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:letterSpacing="0"
            android:text="Add Discount"
            android:textAllCaps="false"
            android:textColor="#1F2937"
            android:textSize="13sp"
            android:textStyle="bold"
            app:icon="@drawable/sell"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="18dp"
            app:iconTint="#F97316"
            app:cornerRadius="8dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/discountSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_order_discount_summary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_icon_discount"
                android:gravity="center">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_discount" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDiscountSummaryTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Diskon"
                    android:textColor="#334155"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDiscountSummarySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="Member - KW"
                    android:textColor="#64748B"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtDiscountSummaryAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-Rp 0"
                android:textColor="#EA580C"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnRemoveDiscountSummary"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="x"
                android:textColor="#94A3B8"
                android:textSize="16sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPayment"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:backgroundTint="#1A0DAB"
            android:text="Lanjut ke Pembayaran"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

    </LinearLayout>
</LinearLayout>
