<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FC"
    android:orientation="vertical">

    <include
        android:id="@+id/globalHeader"
        layout="@layout/layout_global_header" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_orders_summary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual Inquiry"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/inquirySummaryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Transaksi yang hasilnya belum final"
                    android:textColor="#64748B"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/inquiryCountChip"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_orders_count_chip"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="0 Transaksi"
                android:textColor="#1E00A8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnRefreshInquiry"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_orders_count_chip"
                android:contentDescription="Muat ulang daftar"
                android:padding="8dp"
                android:src="@drawable/ic_refresh"
                app:tint="#1E00A8" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/pendingRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="18dp" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="gone">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_orders_empty_icon"
                android:gravity="center"
                android:text="0"
                android:textColor="#1E00A8"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Tidak ada transaksi tertunda"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Transaksi APOS yang hasilnya belum final akan muncul di sini untuk dicek ulang."
                android:textColor="#64748B"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
